	StartPermissive.M_Set(1, 'MyServo01 at Move 1: Home', MyServo01.M_CheckAtPosition(Position:= MyServo01Moves[1].Position, Tolerance := 0.5);	//Using a servo position as a condition
	StartPermissive.M_Set(		//Using multiple lines when one line is too long for the screen
