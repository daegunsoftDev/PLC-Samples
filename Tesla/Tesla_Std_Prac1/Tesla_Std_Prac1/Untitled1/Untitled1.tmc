*Declaration Sample:*

.. code:: structured text
    
    PROGRAM MAIN
	VAR
		StartPermissive	: FB_PermIntlk;		//Conditions that must be met in order to start some device
		RunInterlock	: FB_PermIntlk;		//Conditions that must be met for the duration some device is running
		ZoneSafety		: FB_PermIntlk;		//All safety devices that must be ok for zone safety to be ok
	END_VAR
     
          
*Implementation Sample:*
    
.. code:: structured text
    
    //Sample Code Block:
		 
	//Zone Safeties
	ZoneSafety.P_Name:= 'Zone Safety';
	ZoneSafety.M_Set(0, 'Front E-Stop', EStop01.P_DeviceOK);									//Using a safety device as a condition
	ZoneSafety.M_Set(1, EStop02.P_Configuration.Definition.DisplayName, EStop02.P_DeviceOK);	//Using the configured name of the device as the description
	ZoneSafety.M_Set(2, 'Gate Locked', Gate01.P_GateStatus.GateLocked);
	ZoneSafety.M_Set(3, 'Light Curtain', LightCurtain.P_DeviceOK);
	ZoneSafety();		//Call the FB to evaluate the conditions
		 
	//Start Permissives		  
	StartPermissive.P_Name := 'Device01 Start Permissives';
