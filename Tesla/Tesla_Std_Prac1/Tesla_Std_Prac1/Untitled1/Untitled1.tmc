================
3. Configuration Sample
================

*Declaration Sample:*

.. code:: 
    
    PROGRAM BSIL_010
    VAR
        //Tool Examples------------------------------
                //TL01	
                    TL01_EM							: FB_ExampleEMControl;		
                    TL01_EMData						: ST_ExampleEM;
                    //Valves
                        TL01_VM01_CV01_Cylinders	: ARRAY[1..4] OF ST_ActuatorComponent;
                        TL01_VM01_CV01				: FB_ActuatorMultiComponent(Components:=ADR(TL01_VM01_CV01_Cylinders), LowerMin:=1, UpperMax:=4);
                        TL01_VM01_CV02_Cylinders	: ARRAY[1..5] OF ST_ActuatorComponent;
                        TL01_VM01_CV02				: FB_ActuatorMultiComponent(Components:=ADR(TL01_VM01_CV02_Cylinders), LowerMin:=1, UpperMax:=5);
                        TL01_VM01_CV03_Cylinders	: ARRAY[1..4] OF ST_ActuatorComponent;
                        TL01_VM01_CV03				: FB_ActuatorMultiComponent(Components:=ADR(TL01_VM01_CV03_Cylinders), LowerMin:=1, UpperMax:=4);
    END_VAR
     
          
*Implementation Sample:*
    
.. code:: 
    
    //Sample Code Block:
         
    Tick(IN:= NOT Tock.Q, PT:= T#1S);
    Tock(IN:= Tick.Q, PT:= T#1S);
    Flasher := Tock.IN;
    
    //Zone safety
    ZoneSafetyOK.M_SetAll(0,TRUE,'E-Stop 1', EStop1);
    ZoneSafetyOK.M_SetAll(1,TRUE,'E-Stop 2', EStop2);
    ZoneSafetyOK.M_SetAll(2,TRUE,'Gate 1', Gate1);
    ZoneSafetyOK.M_SetAll(3,TRUE,'Gate 2', Gate2);
    
    //Rebuild Example definitions on first scan
    IF TL01_Data.BuildDefinition THEN
        M_TL01_EMConfig();
    END_IF

     
